rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /feedback_posts/{postId} {
      allow read: if true;

      allow create: if validCreate();

      allow update, delete: if request.auth != null;

      function validCreate() {
        let d = request.resource.data;
        return d.id == postId
          && d.status == 'open'
          && d.category in ['improvement', 'bug', 'other']
          && d.body is string
          && d.body.size() >= 10
          && d.body.size() <= 1200
          && d.author is string
          && d.author.size() >= 1
          && d.author.size() <= 24
          && d.createdAt is string
          && d.title is string
          && d.title.size() <= 200
          && d.utilityId is string
          && d.utilityName is string;
      }
    }
  }
}
